# Tracked on purpose (do NOT add patterns that hide these):
#   LICENSE, README.md, package.json, CLAUDE.md, bin/, src/, tests/

# Dependencies (not in package.json today; ignore if you npm install locally)
node_modules/

# npm pack / publish
*.tgz

# Secrets / local env
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage (if you add c8/nyc later)
coverage/
.nyc_output/

# If someone runs `init` / `init --vendor-only` in this repo root, these are
# consumer outputs — not part of the published package source.
vendor/
.ai/
.claude/
.cursor/
.cursor-plugin/
.cursorrules
.claudeignore
.cursorignore
# Root docs/ is created by init (ARCHITECTURE.md, etc.). Ignore consumer output
# but track maintainer docs under docs/guide/, docs/reference/, docs/superpowers/.
/docs/*
!/docs/guide/
!/docs/guide/**
!/docs/reference/
!/docs/reference/**
!/docs/superpowers/
!/docs/superpowers/**

# OS
.DS_Store
Thumbs.db

# Editor (drop .idea/ if your team commits JetBrains config)
.idea/
*.swp
*.swo
*~
